<Page x:Class="Uno.Extensions.Navigation.UI.Tests.Pages.HotReloadTabBarXamlPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:uen="using:Uno.Extensions.Navigation.UI"
	  xmlns:utu="using:Uno.Toolkit.UI">
	<Grid uen:Region.Attached="True">
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid x:Name="_contentGrid" Grid.Row="0" uen:Region.Attached="True" uen:Region.Navigator="Visibility" />
		<utu:TabBar x:Name="TB" Grid.Row="1" uen:Region.Attached="True">
			<utu:TabBarItem Content="Tab One" uen:Region.Name="TabOne" IsSelectable="True" />
			<utu:TabBarItem Content="Tab Two" uen:Region.Name="TabTwo" IsSelectable="True" />
		</utu:TabBar>
	</Grid>
</Page>
