{
  "openapi": "3.0.3",
  "info": {
    "title": "Error Responses Test API",
    "description": "Test API for error response code generation patterns, including typed error models that extend ApiException, multiple error types for different status codes, and nested error structures.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.example.com/v1"
    }
  ],
  "paths": {
    "/resources": {
      "get": {
        "operationId": "listResources",
        "summary": "List resources",
        "description": "Returns resources with standard error responses.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of resources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Resource"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizationError"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalError"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceUnavailableError"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createResource",
        "summary": "Create a resource",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateResourceRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Resource created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeneralError"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeneralError"
                }
              }
            }
          }
        }
      }
    },
    "/resources/{resourceId}": {
      "get": {
        "operationId": "getResource",
        "summary": "Get a resource by ID",
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          },
          "4XX": {
            "description": "Other client error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeneralError"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteResource",
        "summary": "Delete a resource",
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Resource deleted"
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          },
          "409": {
            "description": "Conflict — resource has dependents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConflictError"
                }
              }
            }
          },
          "4XX": {
            "description": "Other client error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeneralError"
                }
              }
            }
          }
        }
      }
    },
    "/resources/{resourceId}/operations": {
      "post": {
        "operationId": "executeOperation",
        "summary": "Execute an operation on a resource",
        "description": "Tests endpoint with void success response but typed error responses.",
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OperationRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Operation accepted"
          },
          "400": {
            "description": "Invalid operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Resource": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "archived"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Arbitrary key-value metadata"
          }
        }
      },
      "CreateResourceRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "OperationRequest": {
        "type": "object",
        "required": [
          "operationType"
        ],
        "properties": {
          "operationType": {
            "type": "string",
            "enum": [
              "activate",
              "deactivate",
              "archive",
              "restore",
              "clone"
            ]
          },
          "parameters": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "GeneralError": {
        "type": "object",
        "description": "General-purpose error model — generates a class extending ApiException",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Machine-readable error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "requestId": {
            "type": "string",
            "description": "Unique request identifier for tracing"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When the error occurred"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "description": "Validation error with field-level details",
        "required": [
          "code",
          "message",
          "errors"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldError"
            },
            "description": "Field-level validation errors"
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "FieldError": {
        "type": "object",
        "description": "A single field validation error",
        "properties": {
          "field": {
            "type": "string",
            "description": "Name of the field that failed validation"
          },
          "message": {
            "type": "string",
            "description": "Validation error message"
          },
          "rejectedValue": {
            "type": "string",
            "description": "The value that was rejected"
          },
          "constraint": {
            "type": "string",
            "description": "The constraint that was violated (e.g. 'required', 'maxLength')"
          }
        }
      },
      "AuthenticationError": {
        "type": "object",
        "description": "Authentication error — missing or invalid credentials",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "realm": {
            "type": "string",
            "description": "Authentication realm"
          },
          "scheme": {
            "type": "string",
            "description": "Expected authentication scheme (e.g. Bearer)"
          }
        }
      },
      "AuthorizationError": {
        "type": "object",
        "description": "Authorization error — insufficient permissions",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "requiredPermission": {
            "type": "string",
            "description": "The permission required for this action"
          },
          "resource": {
            "type": "string",
            "description": "The resource path that was denied"
          }
        }
      },
      "NotFoundError": {
        "type": "object",
        "description": "Resource not found error",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "resourceType": {
            "type": "string",
            "description": "Type of resource that was not found"
          },
          "resourceId": {
            "type": "string",
            "description": "ID of the resource that was not found"
          }
        }
      },
      "ConflictError": {
        "type": "object",
        "description": "Conflict error — resource state conflicts with the request",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "conflictingResources": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of resources causing the conflict"
          },
          "suggestedAction": {
            "type": "string",
            "description": "Suggested user action to resolve the conflict"
          }
        }
      },
      "RateLimitError": {
        "type": "object",
        "description": "Rate limit exceeded error",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "retryAfterSeconds": {
            "type": "integer",
            "format": "int32",
            "description": "Number of seconds before the client should retry"
          },
          "limit": {
            "type": "integer",
            "format": "int32",
            "description": "The rate limit ceiling"
          },
          "remaining": {
            "type": "integer",
            "format": "int32",
            "description": "Number of requests remaining in the current window"
          },
          "resetAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the rate limit window resets"
          }
        }
      },
      "InternalError": {
        "type": "object",
        "description": "Internal server error — unexpected failure",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "traceId": {
            "type": "string",
            "description": "Distributed tracing identifier"
          },
          "innerError": {
            "$ref": "#/components/schemas/InnerError"
          }
        }
      },
      "ServiceUnavailableError": {
        "type": "object",
        "description": "Service temporarily unavailable",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "retryAfterSeconds": {
            "type": "integer",
            "format": "int32"
          },
          "maintenanceWindow": {
            "$ref": "#/components/schemas/MaintenanceWindow"
          }
        }
      },
      "InnerError": {
        "type": "object",
        "description": "Nested error details for debugging",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "stackTrace": {
            "type": "string",
            "description": "Stack trace (only in development)"
          },
          "innerError": {
            "$ref": "#/components/schemas/InnerError",
            "description": "Recursively nested inner error"
          }
        }
      },
      "MaintenanceWindow": {
        "type": "object",
        "description": "Scheduled maintenance window information",
        "properties": {
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
