<Page x:Class="TestHarness.Ext.Navigation.TabBar.TabBarClearBackStack.TabBarClearBackStackMyRunPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  mc:Ignorable="d"
	  NavigationCacheMode="Required"
	  AutomationProperties.AutomationId="MyRunSection"
	  Background="LightYellow">

	<Grid>
		<StackPanel HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Spacing="20">
			<TextBlock Text="MyRun Tab"
					   AutomationProperties.AutomationId="MyRunSectionText"
					   FontSize="24"
					   HorizontalAlignment="Center" />
			<Button Content="Go to Stop Details"
					AutomationProperties.AutomationId="GoToStopDetailsButton"
					Click="GoToStopDetails_Click"
					HorizontalAlignment="Center" />
		</StackPanel>
	</Grid>
</Page>
