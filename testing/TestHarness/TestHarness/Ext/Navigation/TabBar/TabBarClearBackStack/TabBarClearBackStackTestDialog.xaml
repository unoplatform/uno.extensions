<ContentDialog
    x:Class="TestHarness.Ext.Navigation.TabBar.TabBarClearBackStack.TabBarClearBackStackTestDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Test Dialog"
    CloseButtonText="Cancel"
    DefaultButton="Close">
    <StackPanel Spacing="12" Margin="12">
        <TextBlock Text="This dialog should be dismissed when navigating to root."
                   TextWrapping="Wrap"
                   AutomationProperties.AutomationId="DialogContentText" />
        <Button Content="Navigate to /Root/Home"
                AutomationProperties.AutomationId="DialogNavToRootButton"
                Click="NavToRoot_Click" />
    </StackPanel>
</ContentDialog>
