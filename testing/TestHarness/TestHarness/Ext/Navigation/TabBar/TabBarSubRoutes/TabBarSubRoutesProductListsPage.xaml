<Page x:Class="TestHarness.Ext.Navigation.TabBar.TabBarSubRoutesProductListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="LightBlue">

	<!--
		Intermediate page navigated to by both TabBarItems on HomePage.
		It exposes a content area where the AllProducts or Favorites sub-page
		is rendered based on whichever sub-route was requested.
	-->
	<Grid uen:Region.Attached="True">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition />
		</Grid.RowDefinitions>

		<utu:NavigationBar Content="Product Lists"
						   AutomationProperties.AutomationId="TabBarSubRoutesProductListsNavigationBar" />

		<!-- Sub-content area: shows AllProducts or Favorites page -->
		<ContentControl Grid.Row="1"
						uen:Region.Attached="True"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch"
						HorizontalContentAlignment="Stretch"
						VerticalContentAlignment="Stretch"
						AutomationProperties.AutomationId="ProductListsContentControl" />
	</Grid>
</Page>
