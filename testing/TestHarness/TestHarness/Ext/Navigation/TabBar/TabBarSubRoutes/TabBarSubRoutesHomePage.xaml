<Page x:Class="TestHarness.Ext.Navigation.TabBar.TabBarSubRoutesHomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="LightBlue">

	<!--
		Sub-Routes Demo:
		Two TabBarItems target the same base region ("Home") but navigate to different
		sub-routes within it. Using composite region names "Home/Products" and
		"Home/Favorites" causes the TabBarNavigator to select the correct item when
		navigating to either sub-route programmatically.
	-->
	<Grid uen:Region.Attached="True">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<utu:NavigationBar Content="TabBar Sub-Routes Home"
						   AutomationProperties.AutomationId="TabBarSubRoutesHomeNavigationBar" />

		<!-- Content area: FrameView-based content per tab -->
		<Grid Grid.Row="1"
			  uen:Region.Attached="True"
			  uen:Region.Navigator="Visibility" />

		<!-- TabBar: two items use composite region names targeting the same base region -->
		<utu:TabBar Grid.Row="2"
					uen:Region.Attached="True">
			<utu:TabBarItem AutomationProperties.AutomationId="HomeProductsTabBarItem"
							IsSelectable="True"
							Content="Products"
							uen:Region.Name="Home/Products" />
			<utu:TabBarItem AutomationProperties.AutomationId="HomeFavoritesTabBarItem"
							IsSelectable="True"
							Content="Favorites"
							uen:Region.Name="Home/Favorites" />
		</utu:TabBar>
	</Grid>
</Page>
