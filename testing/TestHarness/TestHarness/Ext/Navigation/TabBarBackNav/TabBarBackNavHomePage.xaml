<Page x:Class="TestHarness.Ext.Navigation.TabBarBackNav.TabBarBackNavHomePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:uen="using:Uno.Extensions.Navigation.UI"
	  xmlns:utu="using:Uno.Toolkit.UI"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  mc:Ignorable="d"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid uen:Region.Attached="True">
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0"
			  uen:Region.Attached="True"
			  uen:Region.Navigator="Visibility" />

		<utu:TabBar x:Name="BottomTabBar"
					AutomationProperties.AutomationId="TabBarBackNavTabBar"
					Grid.Row="1"
					uen:Region.Attached="True">
			<utu:TabBarItem uen:Region.Name="Second"
							AutomationProperties.AutomationId="SecondTabBarItem"
							Content="Second" />
			<utu:TabBarItem uen:Region.Name="Third"
							AutomationProperties.AutomationId="ThirdTabBarItem"
							Content="Third" />
			<utu:TabBarItem uen:Region.Name="Fourth"
							AutomationProperties.AutomationId="FourthTabBarItem"
							Content="Fourth" />
		</utu:TabBar>

		<Button Grid.Row="2"
				Content="Go to Sibling Page"
				AutomationProperties.AutomationId="GoToSiblingButton"
				uen:Navigation.Request="Sibling"
				HorizontalAlignment="Center"
				Margin="0,12" />
	</Grid>
</Page>
