<Page x:Class="TestHarness.Ext.Navigation.TabBarBackNav.TabBarBackNavThirdPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:uen="using:Uno.Extensions.Navigation.UI"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  mc:Ignorable="d"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid>
		<StackPanel HorizontalAlignment="Center"
					VerticalAlignment="Center">
			<TextBlock Text="Third Page"
					   AutomationProperties.AutomationId="TabBarBackNavThirdPageText"
					   FontSize="24" />
			<Button Content="Go to Sibling Page"
					AutomationProperties.AutomationId="ThirdGoToSiblingButton"
					uen:Navigation.Request="Sibling"
					Margin="0,20,0,0" />
		</StackPanel>
	</Grid>
</Page>
