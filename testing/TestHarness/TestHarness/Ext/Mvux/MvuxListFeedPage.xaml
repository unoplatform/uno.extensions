<Page x:Class="TestHarness.Ext.Mvux.MvuxListFeedPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
	  xmlns:ui="using:Uno.Extensions.Reactive.UI"
	  mc:Ignorable="d"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid>
		<StackPanel HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Spacing="8">
			<TextBlock Text="ListFeed Test"
					   FontSize="24" />
			<ui:FeedView Source="{Binding Items}">
				<ui:FeedView.ValueTemplate>
					<DataTemplate>
						<StackPanel Spacing="4">
							<TextBlock AutomationProperties.AutomationId="MvuxListFeedItemCount"
									   FontSize="18">
								<Run Text="Count: " />
								<Run Text="{Binding Data.Count}" />
							</TextBlock>
							<muxc:ItemsRepeater AutomationProperties.AutomationId="MvuxListFeedItems"
												 ItemsSource="{Binding Data}">
								<muxc:ItemsRepeater.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding Name}"
												   FontSize="16"
												   Padding="0,4" />
									</DataTemplate>
								</muxc:ItemsRepeater.ItemTemplate>
							</muxc:ItemsRepeater>
						</StackPanel>
					</DataTemplate>
				</ui:FeedView.ValueTemplate>
				<ui:FeedView.ProgressTemplate>
					<DataTemplate>
						<ProgressRing AutomationProperties.AutomationId="MvuxListFeedLoading"
									  IsActive="True" />
					</DataTemplate>
				</ui:FeedView.ProgressTemplate>
			</ui:FeedView>
		</StackPanel>
	</Grid>
</Page>
